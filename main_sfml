using namespace std;

struct Pos
{
    int r, c;
    bool operator<(const Pos &other) const
    {
        if (r != other.r)
            return r < other.r;
        return c < other.c;
    }
    bool operator==(const Pos &other) const
    {
        return r == other.r && c == other.c;
    }
};

struct Node
{
    Pos pos;
    double fCost;
    bool operator>(const Node &other) const { return fCost > other.fCost; }
};

struct Bubble
{
    float x, y;
    float vx, vy;
    float life;
    float maxLife;
    float size;
};

const int ROWS = 25;
const int COLS = 25;
const int CELL_SIZE = 24;
const int WINDOW_WIDTH = COLS * CELL_SIZE + 250;
const int WINDOW_HEIGHT = ROWS * CELL_SIZE + 50;

enum Algorithm { ASTAR = 1, DIJKSTRA = 2, BFS = 3 };
enum GameState { MENU, WALL_DESIGN, START_SELECTION, END_SELECTION, RUNNING, FINISHED };
enum DragMode { NONE, DRAGGING_START, DRAGGING_END };

class PathfindingVisualizer
{
private:
    sf::RenderWindow window;
    vector<vector<char>> grid;
    vector<vector<int>> cellState;
    vector<vector<float>> cellAnimation;  // For scale animation
    sf::Font font;
    GameState state;
    Algorithm currentAlgo;
    int designChoice;
    Pos startPos, endPos;
    int totalChecks;
    double timeTaken;
    double pathLength;
    bool pathFound;
    string statusMessage;
    DragMode dragMode;
    vector<Bubble> bubbles;
    vector<Pos> pathToAnimate;
    int pathAnimationIndex;
    bool animatingPath;

    vector<sf::RectangleShape> buttons;
    vector<string> buttonLabels;

public:
    PathfindingVisualizer() : window(sf::VideoMode(sf::Vector2u(WINDOW_WIDTH, WINDOW_HEIGHT)), "Pathfinding Visualizer")
    {
        window.setFramerateLimit(60);
        
        if (!font.openFromFile("C:\\Windows\\Fonts\\arial.ttf"))
        {
            cerr << "Warning: Could not load font" << endl;
        }

        state = MENU;
        currentAlgo = ASTAR;
        designChoice = 1;
        totalChecks = 0;
        timeTaken = 0;
        pathLength = 0;
        pathFound = false;
        statusMessage = "";
        dragMode = NONE;
        pathAnimationIndex = 0;
        animatingPath = false;

        // FIX #1: Initialize startPos and endPos to sentinel values
        startPos = {-1, -1};
        endPos = {-1, -1};

        grid.assign(ROWS, vector<char>(COLS, ' '));
        cellState.assign(ROWS, vector<int>(COLS, 0));
        cellAnimation.assign(ROWS, vector<float>(COLS, 1.0f));
        initializeMenu();
    }

    void run()
    {
        while (window.isOpen())
        {
            handleEvents();
            update();
            render();
        }
    }

private:
    void handleEvents()
    {
        while (auto event = window.pollEvent())
        {
            if (event->is<sf::Event::Closed>())
                window.close();

            if (event->is<sf::Event::MouseButtonPressed>())
            {
                auto mouseClick = event->getIf<sf::Event::MouseButtonPressed>();
                if (mouseClick)
                    handleMouseClick(mouseClick->position.x, mouseClick->position.y);
            }

            if (event->is<sf::Event::MouseButtonReleased>())
            {
                dragMode = NONE;
            }

            if (event->is<sf::Event::MouseMoved>())
            {
                auto mouseMoved = event->getIf<sf::Event::MouseMoved>();
                // FIX #3: Only handle drag if actually dragging (dragMode != NONE)
                if (mouseMoved && state == END_SELECTION && dragMode != NONE)
                {
                    handleMouseDrag(mouseMoved->position.x, mouseMoved->position.y);
                }
            }
        }
    }

    void handleMouseClick(int x, int y)
    {
        if (state == MENU)
        {
            for (size_t i = 0; i < buttons.size(); i++)
            {
                if (buttons[i].getGlobalBounds().contains(sf::Vector2f(x, y)))
                {
                    currentAlgo = (Algorithm)(i + 1);
                    state = WALL_DESIGN;
                    initializeWallDesignMenu();
                    break;
                }
            }
        }
        else if (state == WALL_DESIGN)
        {
            for (size_t i = 0; i < buttons.size(); i++)
            {
                if (buttons[i].getGlobalBounds().contains(sf::Vector2f(x, y)))
                {
                    designChoice = i + 1;
                    createWallDesign(designChoice);
                    cellState.assign(ROWS, vector<int>(COLS, 0));
                    cellAnimation.assign(ROWS, vector<float>(COLS, 1.0f));
                    state = START_SELECTION;
                    statusMessage = "Click to set START position (green) - drag to move";
                    break;
                }
            }
        }
        else if (state == START_SELECTION)
        {
            int col = x / CELL_SIZE;
            int row = y / CELL_SIZE;

            if (row >= 0 && row < ROWS && col >= 0 && col < COLS && grid[row][col] != '#')
            {
                startPos = {row, col};
                grid[row][col] = 'S';
                dragMode = DRAGGING_START;
                state = END_SELECTION;
                statusMessage = "Click to set END position (red) - drag to move";
                initializeEndSelectionMenu();
            }
        }
        else if (state == END_SELECTION)
        {
            // Check for button clicks first
            for (size_t i = 0; i < buttons.size(); i++)
            {
                if (buttons[i].getGlobalBounds().contains(sf::Vector2f(x, y)))
                {
                    if (buttonLabels[i] == "Run" && endPos.r >= 0 && endPos.c >= 0)
                    {
                        state = RUNNING;
                        runAlgorithm();
                        return;
                    }
                }
            }

            int col = x / CELL_SIZE;
            int row = y / CELL_SIZE;

            if (row >= 0 && row < ROWS && col >= 0 && col < COLS && grid[row][col] != '#')
            {
                // Check if clicking on start point to drag it
                if (row == startPos.r && col == startPos.c)
                {
                    dragMode = DRAGGING_START;
                    return;
                }

                // Check if clicking on end point to drag it
                if (row == endPos.r && col == endPos.c)
                {
                    dragMode = DRAGGING_END;
                    return;
                }

                // Set end point
                if (!(row == startPos.r && col == startPos.c))
                {
                    // FIX #2: Guard against uninitialized endPos
                    if (endPos.r >= 0 && endPos.c >= 0)
                        grid[endPos.r][endPos.c] = ' ';
                    
                    endPos = {row, col};
                    grid[row][col] = 'E';
                    dragMode = DRAGGING_END;
                }
            }
        }
        else if (state == FINISHED)
        {
            for (size_t i = 0; i < buttons.size(); i++)
            {
                if (buttons[i].getGlobalBounds().contains(sf::Vector2f(x, y)))
                {
                    if (buttonLabels[i] == "Run Again")
                    {
                        state = MENU;
                        grid.assign(ROWS, vector<char>(COLS, ' '));
                        cellState.assign(ROWS, vector<int>(COLS, 0));
                        cellAnimation.assign(ROWS, vector<float>(COLS, 1.0f));
                        bubbles.clear();
                        totalChecks = 0;
                        timeTaken = 0;
                        pathLength = 0;
                        startPos = {-1, -1};
                        endPos = {-1, -1};
                        initializeMenu();
                    }
                    else if (buttonLabels[i] == "Exit Program")
                    {
                        window.close();
                    }
                    break;
                }
            }
        }
    }

    void handleMouseDrag(int x, int y)
    {
        int col = x / CELL_SIZE;
        int row = y / CELL_SIZE;

        if (row < 0 || row >= ROWS || col < 0 || col >= COLS || grid[row][col] == '#')
            return;

        if (dragMode == DRAGGING_START)
        {
            if (!(row == endPos.r && col == endPos.c))
            {
                grid[startPos.r][startPos.c] = ' ';
                startPos = {row, col};
                grid[row][col] = 'S';
                createBubbles(row, col, 3);
            }
        }
        else if (dragMode == DRAGGING_END)
        {
            if (!(row == startPos.r && col == startPos.c))
            {
                grid[endPos.r][endPos.c] = ' ';
                endPos = {row, col};
                grid[row][col] = 'E';
                createBubbles(row, col, 3);
            }
        }
    }

    void createBubbles(int row, int col, int count)
    {
        // FIX #2: Cap bubble count to prevent lag
        if (bubbles.size() > 200) return;

        for (int i = 0; i < count; i++)
        {
            Bubble b;
            b.x = col * CELL_SIZE + CELL_SIZE / 2;
            b.y = row * CELL_SIZE + CELL_SIZE / 2;
            b.vx = (rand() % 100 - 50) / 50.0f;
            b.vy = (rand() % 100 - 50) / 50.0f;
            b.life = 1.0f;
            b.maxLife = 1.0f;
            b.size = 3.0f + (rand() % 5);
            bubbles.push_back(b);
        }
    }

    void initializeMenu()
    {
        buttons.clear();
        buttonLabels.clear();

        vector<string> algoNames = {"A* (Heuristic)", "Dijkstra", "BFS"};
        
        for (size_t i = 0; i < algoNames.size(); i++)
        {
            sf::RectangleShape btn(sf::Vector2f(200, 50));
            btn.setPosition(sf::Vector2f(COLS * CELL_SIZE + 20, 100 + i * 70));
            btn.setFillColor(sf::Color(100, 150, 255));
            buttons.push_back(btn);
            buttonLabels.push_back(algoNames[i]);
        }
        statusMessage = "Select Algorithm";
    }

    void initializeWallDesignMenu()
    {
        buttons.clear();
        buttonLabels.clear();

        vector<string> designs = {"Cross", "Diagonal", "Rooms", "Spiral", "Random"};
        
        for (size_t i = 0; i < designs.size(); i++)
        {
            sf::RectangleShape btn(sf::Vector2f(200, 40));
            btn.setPosition(sf::Vector2f(COLS * CELL_SIZE + 20, 100 + i * 50));
            btn.setFillColor(sf::Color(150, 200, 100));
            buttons.push_back(btn);
            buttonLabels.push_back(designs[i]);
        }
        statusMessage = "Select Wall Design";
    }

    void initializeEndSelectionMenu()
    {
        buttons.clear();
        buttonLabels.clear();

        sf::RectangleShape runBtn(sf::Vector2f(200, 50));
        runBtn.setPosition(sf::Vector2f(COLS * CELL_SIZE + 20, 400));
        runBtn.setFillColor(sf::Color(255, 200, 50));
        buttons.push_back(runBtn);
        buttonLabels.push_back("Run");
    }

    void createWallDesign(int design)
    {
        for (int i = 0; i < ROWS; i++)
            for (int j = 0; j < COLS; j++)
                grid[i][j] = ' ';

        if (design == 1)
        {
            for (int j = 0; j < COLS; j++)
                grid[ROWS / 2][j] = '#';
            for (int i = 0; i < ROWS; i++)
                grid[i][COLS / 2] = '#';
            
            for (int i = ROWS / 2 - 3; i <= ROWS / 2 + 3; i++)
                grid[i][COLS / 2] = ' ';
            for (int j = COLS / 2 - 3; j <= COLS / 2 + 3; j++)
                grid[ROWS / 2][j] = ' ';
            
            for (int i = 0; i < ROWS; i++)
            {
                if (i % 4 == 0)
                {
                    grid[i][i] = '#';
                    if (i < ROWS) grid[i][COLS - 1 - i] = '#';
                }
            }
        }
        else if (design == 2)
        {
            for (int i = 0; i < ROWS; i++)
            {
                for (int j = 0; j < COLS; j++)
                {
                    if ((i + j) % 5 == 0 && (i + j) % 7 != 0)
                        grid[i][j] = '#';
                }
            }
        }
        else if (design == 3)
        {
            for (int i = 0; i < ROWS; i += 6)
            {
                for (int j = 1; j < COLS; j++)
                {
                    grid[i][j] = '#';
                }
                for (int k = 0; k < COLS; k += 6)
                    grid[i][k] = ' ';
            }
            
            for (int j = 0; j < COLS; j += 6)
            {
                for (int i = 1; i < ROWS; i++)
                {
                    grid[i][j] = ' ';
                }
            }
        }
        else if (design == 4)
        {
            int centerR = ROWS / 2;
            int centerC = COLS / 2;
            
            for (int i = 0; i < ROWS; i++)
            {
                for (int j = 0; j < COLS; j++)
                {
                    int dist = max(abs(i - centerR), abs(j - centerC));
                    if (dist % 4 == 0 && dist > 0)
                        grid[i][j] = '#';
                }
            }
            
            for (int k = 0; k < COLS / 2; k += 4)
            {
                grid[centerR][centerC + k] = ' ';
                grid[centerR + k][centerC] = ' ';
            }
        }
        else if (design == 5)
        {
            for (int i = 0; i < ROWS; i++)
            {
                for (int j = 0; j < COLS; j++)
                {
                    if ((double)rand() / RAND_MAX < 0.15)
                        grid[i][j] = '#';
                }
            }
        }
    }

    double getH(Pos a, Pos b)
    {
        return sqrt(pow(a.r - b.r, 2) + pow(a.c - b.c, 2));
    }

    void renderLive()
    {
        window.clear(sf::Color::Black);

        for (int i = 0; i < ROWS; i++)
        {
            for (int j = 0; j < COLS; j++)
            {
                sf::RectangleShape cell(sf::Vector2f(CELL_SIZE - 1, CELL_SIZE - 1));
                cell.setPosition(sf::Vector2f(j * CELL_SIZE, i * CELL_SIZE));

                sf::Color color = sf::Color::White;
                if (grid[i][j] == '#')
                    color = sf::Color::Black;
                else if (grid[i][j] == 'S')
                    color = sf::Color::Green;
                else if (grid[i][j] == 'E')
                    color = sf::Color::Red;
                else if (grid[i][j] == '*')
                    color = sf::Color::Yellow;
                else if (cellState[i][j] == 3)
                    color = sf::Color(10, 40, 150);
                else if (cellState[i][j] == 2)
                    color = sf::Color(80, 130, 220);
                else if (cellState[i][j] == 1)
                    color = sf::Color(180, 200, 255);

                // Apply scale animation
                float scale = cellAnimation[i][j];
                float offset = (1.0f - scale) * CELL_SIZE / 2;
                cell.setPosition(sf::Vector2f(j * CELL_SIZE + offset, i * CELL_SIZE + offset));
                cell.setSize(sf::Vector2f((CELL_SIZE - 1) * scale, (CELL_SIZE - 1) * scale));
                cell.setFillColor(color);
                window.draw(cell);
            }
        }

        window.display();
    }

    void runAlgorithm()
    {
        if (currentAlgo == ASTAR)
            solveAStar();
        else if (currentAlgo == DIJKSTRA)
            solveDijkstra();
        else
            solveBFS();
    }

    void solveAStar()
    {
        auto startTime = chrono::steady_clock::now();
        priority_queue<Node, vector<Node>, greater<Node>> pq;
        pq.push({startPos, getH(startPos, endPos)});

        map<Pos, Pos> parentOf;
        map<Pos, double> gCost;
        set<Pos> closed;
        gCost[startPos] = 0;

        totalChecks = 0;
        int dr[] = {-1, 1, 0, 0, -1, -1, 1, 1};
        int dc[] = {0, 0, -1, 1, -1, 1, -1, 1};

        pathFound = false;

        while (!pq.empty())
        {
            Pos current = pq.top().pos;
            pq.pop();

            if (closed.find(current) != closed.end())
                continue;

            closed.insert(current);
            if (!(current == startPos || current == endPos))
            {
                cellState[current.r][current.c] = 3;
                cellAnimation[current.r][current.c] = 0.5f;
                createBubbles(current.r, current.c, 1);
            }
            totalChecks++;

            renderLive();

            if (current == endPos)
            {
                pathFound = true;
                break;
            }

            for (int i = 0; i < 8; i++)
            {
                int nr = current.r + dr[i];
                int nc = current.c + dc[i];
                Pos neighbor = {nr, nc};
                double weight = (i < 4) ? 1.0 : 1.414;

                if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS &&
                    grid[nr][nc] != '#' && closed.find(neighbor) == closed.end())
                {
                    double newGCost = gCost[current] + weight;
                    if (gCost.find(neighbor) == gCost.end() || newGCost < gCost[neighbor])
                    {
                        gCost[neighbor] = newGCost;
                        pq.push({neighbor, newGCost + getH(neighbor, endPos)});
                        parentOf[neighbor] = current;
                        if (!(neighbor == startPos || neighbor == endPos))
                            cellState[nr][nc] = 2;
                    }
                }
            }
        }

        auto endTime = chrono::steady_clock::now();
        timeTaken = chrono::duration_cast<chrono::milliseconds>(endTime - startTime).count();

        if (pathFound)
        {
            pathLength = gCost[endPos];
            pathToAnimate.clear();
            Pos temp = parentOf[endPos];
            while (!(temp == startPos))
            {
                pathToAnimate.push_back(temp);
                temp = parentOf[temp];
            }
            reverse(pathToAnimate.begin(), pathToAnimate.end());
            pathAnimationIndex = 0;
            animatingPath = true;
        }

        state = FINISHED;
        statusMessage = pathFound ? "Path found!" : "No path found!";
        initializeFinishMenu();
    }

    void solveDijkstra()
    {
        auto startTime = chrono::steady_clock::now();
        priority_queue<Node, vector<Node>, greater<Node>> pq;
        pq.push({startPos, 0});

        map<Pos, Pos> parentOf;
        map<Pos, double> gCost;
        set<Pos> closed;
        gCost[startPos] = 0;

        totalChecks = 0;
        int dr[] = {-1, 1, 0, 0, -1, -1, 1, 1};
        int dc[] = {0, 0, -1, 1, -1, 1, -1, 1};

        pathFound = false;

        while (!pq.empty())
        {
            Pos current = pq.top().pos;
            pq.pop();

            if (closed.find(current) != closed.end())
                continue;

            closed.insert(current);
            if (!(current == startPos || current == endPos))
            {
                cellState[current.r][current.c] = 3;
                cellAnimation[current.r][current.c] = 0.5f;
                createBubbles(current.r, current.c, 1);
            }
            totalChecks++;

            renderLive();

            if (current == endPos)
            {
                pathFound = true;
                break;
            }

            for (int i = 0; i < 8; i++)
            {
                int nr = current.r + dr[i];
                int nc = current.c + dc[i];
                Pos neighbor = {nr, nc};
                double weight = (i < 4) ? 1.0 : 1.414;

                if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS &&
                    grid[nr][nc] != '#' && closed.find(neighbor) == closed.end())
                {
                    double newGCost = gCost[current] + weight;
                    if (gCost.find(neighbor) == gCost.end() || newGCost < gCost[neighbor])
                    {
                        gCost[neighbor] = newGCost;
                        pq.push({neighbor, newGCost});
                        parentOf[neighbor] = current;
                        if (!(neighbor == startPos || neighbor == endPos))
                            cellState[nr][nc] = 2;
                    }
                }
            }
        }

        auto endTime = chrono::steady_clock::now();
        timeTaken = chrono::duration_cast<chrono::milliseconds>(endTime - startTime).count();

        if (pathFound)
        {
            pathLength = gCost[endPos];
            pathToAnimate.clear();
            Pos temp = parentOf[endPos];
            while (!(temp == startPos))
            {
                pathToAnimate.push_back(temp);
                temp = parentOf[temp];
            }
            reverse(pathToAnimate.begin(), pathToAnimate.end());
            pathAnimationIndex = 0;
            animatingPath = true;
        }

        state = FINISHED;
        statusMessage = pathFound ? "Path found!" : "No path found!";
        initializeFinishMenu();
    }

    void solveBFS()
    {
        auto startTime = chrono::steady_clock::now();
        queue<Pos> q;
        q.push(startPos);

        map<Pos, Pos> parentOf;
        set<Pos> visited;
        visited.insert(startPos);

        totalChecks = 0;
        int dr[] = {-1, 1, 0, 0, -1, -1, 1, 1};
        int dc[] = {0, 0, -1, 1, -1, 1, -1, 1};

        pathFound = false;

        while (!q.empty())
        {
            Pos current = q.front();
            q.pop();
            
            if (!(current == startPos || current == endPos))
            {
                cellState[current.r][current.c] = 3;
                cellAnimation[current.r][current.c] = 0.5f;
                createBubbles(current.r, current.c, 1);
            }
            totalChecks++;

            renderLive();

            if (current == endPos)
            {
                pathFound = true;
                break;
            }

            for (int i = 0; i < 8; i++)
            {
                int nr = current.r + dr[i];
                int nc = current.c + dc[i];
                Pos neighbor = {nr, nc};

                if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS &&
                    grid[nr][nc] != '#' && visited.find(neighbor) == visited.end())
                {
                    visited.insert(neighbor);
                    parentOf[neighbor] = current;
                    q.push(neighbor);
                    if (!(neighbor == startPos || neighbor == endPos))
                        cellState[nr][nc] = 2;
                }
            }
        }

        auto endTime = chrono::steady_clock::now();
        timeTaken = chrono::duration_cast<chrono::milliseconds>(endTime - startTime).count();

        if (pathFound)
        {
            pathLength = 0;
            pathToAnimate.clear();
            Pos temp = parentOf[endPos];
            while (!(temp == startPos))
            {
                pathToAnimate.push_back(temp);
                temp = parentOf[temp];
                pathLength++;
            }
            reverse(pathToAnimate.begin(), pathToAnimate.end());
            pathAnimationIndex = 0;
            animatingPath = true;
        }

        state = FINISHED;
        statusMessage = pathFound ? "Path found!" : "No path found!";
        initializeFinishMenu();
    }

