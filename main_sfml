    void update()
    {
        // Update bubbles
        for (auto it = bubbles.begin(); it != bubbles.end();)
        {
            it->x += it->vx;
            it->y += it->vy;
            it->life -= 0.05f;
            it->vy += 0.1f;  // Gravity
            
            if (it->life <= 0)
                it = bubbles.erase(it);
            else
                ++it;
        }

        // Update cell animations
        for (int i = 0; i < ROWS; i++)
        {
            for (int j = 0; j < COLS; j++)
            {
                if (cellAnimation[i][j] < 1.0f)
                    cellAnimation[i][j] += 0.1f;
                if (cellAnimation[i][j] > 1.0f)
                    cellAnimation[i][j] = 1.0f;
            }
        }

        // Update path animation
        if (animatingPath && pathAnimationIndex < pathToAnimate.size())
        {
            Pos p = pathToAnimate[pathAnimationIndex];
            grid[p.r][p.c] = '*';
            cellAnimation[p.r][p.c] = 0.5f;
            createBubbles(p.r, p.c, 2);
            pathAnimationIndex++;
        }
        else if (animatingPath && pathAnimationIndex >= pathToAnimate.size())
        {
            animatingPath = false;
        }
    }

    void render()
    {
        window.clear(sf::Color::Black);

        for (int i = 0; i < ROWS; i++)
        {
            for (int j = 0; j < COLS; j++)
            {
                sf::RectangleShape cell(sf::Vector2f(CELL_SIZE - 1, CELL_SIZE - 1));
                cell.setPosition(sf::Vector2f(j * CELL_SIZE, i * CELL_SIZE));

                sf::Color color = sf::Color::White;
                if (grid[i][j] == '#')
                    color = sf::Color::Black;
                else if (grid[i][j] == 'S')
                    color = sf::Color::Green;
                else if (grid[i][j] == 'E')
                    color = sf::Color::Red;
                else if (grid[i][j] == '*')
                    color = sf::Color::Yellow;
                else if (cellState[i][j] == 3)
                    color = sf::Color(10, 40, 150);
                else if (cellState[i][j] == 2)
                    color = sf::Color(80, 130, 220);
                else if (cellState[i][j] == 1)
                    color = sf::Color(180, 200, 255);

                float scale = cellAnimation[i][j];
                float offset = (1.0f - scale) * CELL_SIZE / 2;
                cell.setPosition(sf::Vector2f(j * CELL_SIZE + offset, i * CELL_SIZE + offset));
                cell.setSize(sf::Vector2f((CELL_SIZE - 1) * scale, (CELL_SIZE - 1) * scale));
                cell.setFillColor(color);
                window.draw(cell);
            }
        }

        // Draw bubbles
        for (const auto& bubble : bubbles)
        {
            sf::CircleShape circle(bubble.size);
            circle.setPosition(sf::Vector2f(bubble.x - bubble.size, bubble.y - bubble.size));
            sf::Color bubbleColor(100, 150, 255, (int)(255 * bubble.life));
            circle.setFillColor(bubbleColor);
            window.draw(circle);
        }

        // Draw buttons
        for (size_t i = 0; i < buttons.size(); i++)
        {
            window.draw(buttons[i]);

            sf::Text text(font, buttonLabels[i], 14);
            text.setFillColor(sf::Color::Black);
            sf::FloatRect bounds = text.getLocalBounds();
            text.setPosition(sf::Vector2f(
                buttons[i].getPosition().x + (buttons[i].getSize().x - bounds.size.x) / 2,
                buttons[i].getPosition().y + (buttons[i].getSize().y - bounds.size.y) / 2
            ));
            window.draw(text);
        }

        drawStatsPanel();

        window.display();
    }

    void drawStatsPanel()
    {
        int panelX = COLS * CELL_SIZE + 10;
        int panelY = 10;

        sf::Text statusText(font, statusMessage, 14);
        statusText.setPosition(sf::Vector2f(panelX, panelY));
        statusText.setFillColor(sf::Color::White);
        window.draw(statusText);

        if (state == FINISHED)
        {
            sf::Text checksText(font, "Checks: " + to_string(totalChecks), 12);
            checksText.setPosition(sf::Vector2f(panelX, panelY + 280));
            checksText.setFillColor(sf::Color::White);
            window.draw(checksText);

            sf::Text timeText(font, "Time: " + to_string((int)timeTaken) + "ms", 12);
            timeText.setPosition(sf::Vector2f(panelX, panelY + 300));
            timeText.setFillColor(sf::Color::White);
            window.draw(timeText);

            sf::Text pathText(font, "Path Length: " + to_string((int)pathLength), 12);
            pathText.setPosition(sf::Vector2f(panelX, panelY + 320));
            pathText.setFillColor(sf::Color::White);
            window.draw(pathText);
        }
    }
};

int main()
{
    srand((unsigned)time(0));
    PathfindingVisualizer visualizer;
    visualizer.run();
    return 0;
}
